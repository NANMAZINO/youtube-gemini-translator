{
  "name": "yg-translator",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node --test \"extension/**/*.test.js\"",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=80 --test-coverage-include=extension/adapters/gemini/error-policy.ts --test-coverage-include=extension/adapters/storage/settings-storage.ts --test-coverage-include=extension/content/bundle-io.ts --test-coverage-include=extension/content/cache-invalidation.ts --test-coverage-include=extension/content/runtime-event-consumer.ts --test-coverage-include=extension/content/ui-labels.ts --test-coverage-include=extension/domain/retry/with-retry.ts --test-coverage-include=extension/domain/transcript/primitives.ts --test-coverage-include=extension/popup/api-key.ts \"extension/**/*.test.js\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.4.0",
    "@types/chrome": "0.1.38",
    "@types/node": "25.5.0",
    "jsdom": "29.0.1",
    "typescript": "5.9.3",
    "vite": "8.0.2"
  }
}
