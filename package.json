{
  "name": "yg-translator",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node --test \"extension/**/*.test.js\" \"src/**/*.test.js\"",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=80 --test-coverage-include=extension/lib/retry.js --test-coverage-include=extension/lib/errors.js --test-coverage-include=extension/content/utils.js --test-coverage-include=src/**/*.ts \"extension/**/*.test.js\" \"src/**/*.test.js\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test && npm run build",
    "rebuild:check": "npm run check"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.4.0",
    "@types/chrome": "0.1.38",
    "@types/node": "25.5.0",
    "typescript": "5.9.3",
    "vite": "8.0.2"
  }
}
